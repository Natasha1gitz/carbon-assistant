# ── Carbon Footprint Assistant — Environment Configuration ──
# Copy to `.env.local` for local development. NEVER commit real credentials.
# All external services are optional — the app gracefully degrades without them.

# ─────────────────────────────────────────────────────────────
# Google Gemini AI — Personalized reduction insights
# ─────────────────────────────────────────────────────────────
# Set to your Gemini API key for AI-powered insights.
# If omitted or invalid, the app automatically falls back to
# the deterministic rule-based insight engine (zero degradation).
NEXT_PUBLIC_GEMINI_API_KEY=your-gemini-api-key-here

# ─────────────────────────────────────────────────────────────
# Firebase — Anonymous auth + Firestore history persistence
# ─────────────────────────────────────────────────────────────
# If any Firebase key is missing or invalid, the app falls back
# to an in-memory mock store (history is not persisted across
# page refreshes but the app continues to function normally).
NEXT_PUBLIC_FIREBASE_API_KEY=your-firebase-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=123456789
NEXT_PUBLIC_FIREBASE_APP_ID=1:123456789:web:abcdef

# ─────────────────────────────────────────────────────────────
# Feature Flags (for development / testing)
# ─────────────────────────────────────────────────────────────
# USE_GEMINI=false      → Skip Gemini API calls, use rule-based engine only
# USE_FIRESTORE=false   → Skip Firestore, use in-memory mock store
