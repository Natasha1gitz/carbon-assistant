rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Users collection ──────────────────────────────────────────────
    // Each user document is keyed by their Firebase Anonymous Auth UID.
    // Only the authenticated owner can read/write their own data.
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      // ── Footprint entries subcollection ───────────────────────────
      match /footprints/{entryId} {
        allow read: if request.auth != null && request.auth.uid == userId;

        // Only allow creates (no updates/deletes) to preserve history integrity.
        allow create: if request.auth != null
          && request.auth.uid == userId
          && request.resource.data.keys().hasAll(['input', 'result', 'timestamp'])
          && request.resource.data.result.total_annual_kg is number
          && request.resource.data.result.total_annual_kg >= 0;

        allow update, delete: if false;
      }
    }

    // ── Default deny ──────────────────────────────────────────────────
    // All other paths are denied by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
