{
  "$schema": "https://unpkg.com/knip@5/schema-json",
  "entry": ["src/app/**/*.tsx", "src/app/**/*.ts"],
  "project": ["src/**/*.ts", "src/**/*.tsx"],
  "ignoreDependencies": [
    "eslint-config-next",
    "eslint-plugin-jsdoc",
    "eslint-plugin-jsx-a11y",
    "eslint-plugin-security",
    "eslint-plugin-sonarjs",
